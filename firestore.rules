rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    // Each user can read/write only their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Prescriptions ──────────────────────────────────────
    // Users can only access their own prescriptions
    match /prescriptions/{docId} {
      allow read, write: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Adherence Logs ─────────────────────────────────────
    match /adherence_logs/{docId} {
      allow read, write: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── Schedules ──────────────────────────────────────────
    match /schedules/{docId} {
      allow read, write: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ── My Doctor ──────────────────────────────────────────
    match /my_doctor/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Doctors (public read, authenticated write) ─────────
    match /doctors/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && (request.auth.uid == docId
          || request.resource.data.phone == request.auth.token.phone_number);
    }

    // ── Condition Presets (public read, admin write) ───────
    match /condition_presets/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // admin-only via Firebase console
    }
  }
}
